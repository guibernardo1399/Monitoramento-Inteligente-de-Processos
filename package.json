{
  "name": "monitoramento-inteligente-processos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:init": "sqlite3 /tmp/monitoramento-inteligente-processos.db \".read prisma/init.sql\"",
